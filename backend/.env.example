# SteadiDay Backend - Environment Variables Example
# Copy this file to .env and replace placeholder values with real credentials

# Server
PORT=3000
BACKEND_URL=http://localhost:3000

# ====================================
# Client authentication
# ====================================
# APP_CLIENT_KEY must exactly match the EXPO_PUBLIC_APP_CLIENT_KEY in the mobile .env.
# If this value is missing, emergency SMS and AI routes return HTTP 503.
# If this value does not match the mobile app key, requests return HTTP 401.
APP_CLIENT_KEY=

# ====================================
# OpenAI (optional - AI routes return 503 when absent)
# ====================================
OPENAI_API_KEY=your-openai-api-key-here

# ====================================
# Grok (optional - Grok chat route returns 503 when absent)
# ====================================
GROK_API_KEY=your-grok-api-key-here

# ====================================
# Twilio SMS (required for automatic emergency alerts)
# ====================================
# All three Twilio values are required for fall-detection emergency SMS.
# If any are missing, the /api/emergency/sms endpoint returns HTTP 503 twilio_not_configured.
# TWILIO_PHONE_NUMBER must be E.164 format, e.g. +15551234567
# IMPORTANT: Twilio secrets must NEVER be added to mobile code or mobile .env files.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ====================================
# Emergency endpoint secret (optional secondary auth)
# ====================================
EMERGENCY_API_SECRET=your-emergency-api-secret-here
