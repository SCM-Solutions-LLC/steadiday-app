# SteadiDay - Environment Variables Example
# Copy this file to .env and replace the placeholder values with your actual credentials

# ====================================
# Backend connection
# ====================================
# EXPO_PUBLIC_BACKEND_URL is the URL of your deployed backend.
# - For production Android/iOS builds: use your deployed backend URL (e.g. https://api.steadiday.com)
# - Physical device local testing: use your computer LAN IP (e.g. http://192.168.1.25:3000)
#   Physical devices CANNOT reach http://localhost:3000 — that refers to the phone itself.
# - Android emulator local testing: use http://10.0.2.2:3000 (maps to host localhost)
# - iOS Simulator local testing: http://localhost:3000 works (shares host network)
EXPO_PUBLIC_BACKEND_URL=

# ====================================
# Backend authentication
# ====================================
# EXPO_PUBLIC_APP_CLIENT_KEY must exactly match the APP_CLIENT_KEY value set in your backend .env.
# If they do not match, emergency SMS and other authenticated requests will fail with 401.
EXPO_PUBLIC_APP_CLIENT_KEY=
EXPO_PUBLIC_EMERGENCY_API_SECRET=your-emergency-api-secret-here
EXPO_PUBLIC_GA4_API_SECRET=your-ga4-api-secret-here

# ====================================
# RevenueCat
# ====================================
EXPO_PUBLIC_VIBECODE_REVENUECAT_APPLE_KEY=your-revenuecat-apple-key-here
EXPO_PUBLIC_VIBECODE_REVENUECAT_TEST_KEY=your-revenuecat-test-key-here

# ====================================
# Vibecode API Keys (already configured)
# ====================================
EXPO_PUBLIC_VIBECODE_OPENAI_API_KEY=your-openai-key-here
EXPO_PUBLIC_VIBECODE_ANTHROPIC_API_KEY=your-anthropic-key-here
EXPO_PUBLIC_VIBECODE_GROK_API_KEY=your-grok-key-here
EXPO_PUBLIC_VIBECODE_GOOGLE_API_KEY=your-google-api-key-here
EXPO_PUBLIC_VIBECODE_ELEVENLABS_API_KEY=your-elevenlabs-key-here

# ====================================
# OAuth Configuration (REQUIRED FOR SOCIAL LOGIN)
# ====================================
# Follow OAUTH_SETUP_GUIDE.md for detailed setup instructions

# Google OAuth (get from console.cloud.google.com, project: steadiday)
# 1. Open the Google Cloud Console for project "steadiday"
# 2. Enable Google Sign-In API
# 3. Configure OAuth consent screen
# 4. Create iOS Client ID (use bundle ID: com.vibecode.steadiday)
# 5. Create Android Client ID (use package: com.vibecode.steadiday)
# 6. Create Web Client ID (authorized redirect URI: https://auth.expo.io/@scmehta/steadiday)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=YOUR_IOS_CLIENT_ID.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=YOUR_ANDROID_CLIENT_ID.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com

# Facebook OAuth (get from developers.facebook.com)
# 1. Create a Facebook App
# 2. Add Facebook Login product
# 3. Configure iOS platform (use bundle ID: com.vibecode.dailycompanion)
# 4. Get your App ID from Settings > Basic
EXPO_PUBLIC_FACEBOOK_APP_ID=YOUR_FACEBOOK_APP_ID
EXPO_PUBLIC_FACEBOOK_CLIENT_TOKEN=YOUR_FACEBOOK_CLIENT_TOKEN

# ====================================
# Status Indicators
# ====================================
# ✅ When properly configured, Google and Facebook sign-in will work
# ❌ Without these credentials, users will see "Configuration Required" messages
# 📖 See OAUTH_SETUP_GUIDE.md for complete setup instructions
